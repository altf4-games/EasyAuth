  },
  "dependencies": {
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "ioredis-mock": "^8.9.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@altf4-auth/core": "workspace:*"
  }
}

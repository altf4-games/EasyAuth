{
  "name": "@altf4-auth/redis",
  "version": "1.0.0",
  "description": "Redis storage adapter for easy-auth",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",

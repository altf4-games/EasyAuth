{
  "name": "easy-auth-mongo",
  "version": "1.0.0",
  "description": "MongoDB storage adapter for easy-auth",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "mongodb": "^6.6.0"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "easy-auth": "workspace:*"
  }
}

# Copy this file to .env and fill in your details
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM="Your App <noreply@yourapp.com>"

# Must be at least 32 characters
JWT_SECRET=super_secret_jwt_key_that_is_at_least_32_chars_long

# (Optional) The port the express server will listen on
PORT=3000
